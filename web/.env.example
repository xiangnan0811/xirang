# API 地址前缀（生产环境通常为 /api/v1）
VITE_API_BASE_URL=/api/v1

# 开发模式：Vite 代理目标（仅 vite.config.ts 使用）
VITE_PROXY_TARGET=http://127.0.0.1:8080

# 开发模式：当 VITE_API_BASE_URL 为相对路径时的直连后端地址
VITE_DEV_API_DIRECT_URL=http://127.0.0.1:8080/api/v1

# 自定义 WebSocket 地址（留空则自动从 API 地址推导）
# VITE_WS_URL=

# Demo 模式（true 启用 mock 数据，仅用于演示/测试）
# VITE_ENABLE_DEMO_MODE=true
