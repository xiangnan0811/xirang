#!/usr/bin/env bash
# pre-commit hook — 文档新鲜度检查
# 当代码关键文件被修改但对应文档未同步更新时阻止提交。
# 跳过：git commit --no-verify

set -euo pipefail

STAGED=$(git diff --cached --name-only 2>/dev/null || true)

if [ -z "$STAGED" ]; then
  exit 0
fi

WARN=0
MSGS=()

# Returns 0 if the path is ignored (thus can never be staged — check would be unsatisfiable).
is_gitignored() {
  git check-ignore -q "$1" 2>/dev/null
}

check() {
  local trigger="$1"
  local doc="$2"
  local msg="$3"
  # Skip checks whose target doc is gitignored (e.g. local-only CLAUDE.md):
  # the author's intent is to remind about doc sync, but an ignored file can
  # never be staged so the rule would be impossible to satisfy.
  if is_gitignored "$doc"; then
    return
  fi
  if echo "$STAGED" | grep -q "$trigger"; then
    if ! echo "$STAGED" | grep -q "$doc"; then
      MSGS+=("$msg")
      WARN=$((WARN + 1))
    fi
  fi
}

check "backend/internal/model/models.go" "CLAUDE.md" \
  "models.go 已修改，请同步更新 CLAUDE.md 核心领域模型"

check "backend/internal/api/router.go" "backend/README_backend.md" \
  "router.go 已修改，请同步更新 backend/README_backend.md 接口列表"

check "web/src/router.tsx" "CLAUDE.md" \
  "router.tsx 已修改，请同步更新 CLAUDE.md 前端结构"

check "backend/internal/database/migrations/" "CLAUDE.md" \
  "数据库迁移文件有变更，请同步更新 CLAUDE.md 迁移版本"

check "backend/internal/config/config.go" "docs/env-vars.md" \
  "config.go 已修改，请同步更新 docs/env-vars.md"

# 规则 6：发布/镜像/部署/版本检查变更 → 发布相关文档
# 与 scripts/check-doc-freshness.sh 规则对齐：保持两边检查规则一致，避免漂移。
release_trigger_re='^(\.github/workflows/(release-please|publish-images|deploy)\.yml|docker-compose\.prod\.yml|\.env\.deploy|backend/\.env\.production\.example|backend/internal/api/handlers/version_handler\.go|CHANGELOG\.md)$'
release_doc_re='^(README\.md|CONTRIBUTING\.md|docs/deployment\.md|docs/env-vars\.md|docs/release-maintainers\.md|AGENTS\.md|\.github/PULL_REQUEST_TEMPLATE\.md)$'

if echo "$STAGED" | grep -qE "$release_trigger_re"; then
  if ! echo "$STAGED" | grep -qE "$release_doc_re"; then
    MSGS+=("发布/镜像/部署/版本检查相关文件已修改，请同步更新配套文档（README/CONTRIBUTING/docs/deployment.md/docs/env-vars.md/docs/release-maintainers.md/AGENTS.md/PULL_REQUEST_TEMPLATE）")
    WARN=$((WARN + 1))
  fi
fi

if [ "$WARN" -gt 0 ]; then
  echo ""
  echo "[WARN] 文档同步检查未通过（${WARN} 项）："
  echo ""
  for msg in "${MSGS[@]}"; do
    echo "  - $msg"
  done
  echo ""
  echo "请更新对应文档后重新提交，或使用 git commit --no-verify 跳过检查。"
  exit 1
fi

# 当 staged 改动涉及 migration 文件时，跑 UTC 安全 lint。
# 避免在每次 commit 都跑（即使未触及 migrations），保持 hook 的快速反馈。
if echo "$STAGED" | grep -qE "backend/internal/database/migrations/.*\.sql$"; then
  REPO_ROOT="$(git rev-parse --show-toplevel)"
  if [ -x "${REPO_ROOT}/scripts/check-migration-utc-safety.sh" ]; then
    if ! bash "${REPO_ROOT}/scripts/check-migration-utc-safety.sh"; then
      echo ""
      echo "[FAIL] migration UTC 安全检查未通过。修复违规或更新 EXCLUDE_GLOBS。"
      echo "       使用 git commit --no-verify 跳过（不推荐）。"
      exit 1
    fi
  fi
fi

exit 0
