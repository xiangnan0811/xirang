# 服务监听地址
SERVER_ADDR=:8080

# 应用环境（development | production）
APP_ENV=development

# 时区（IANA 名称，如 Asia/Shanghai、UTC、America/New_York）
# 容器环境强烈建议显式设置；未设置时使用系统/镜像默认（通常是 UTC）
# TZ=Asia/Shanghai

# 日志文件路径（可选）
# 设置后日志同时写文件与 stdout，文件以追加模式打开，权限 0o644
# 不设置则仅 stdout（容器场景由 docker / journald 收集）
# 不内置文件轮转，请配合 logrotate / docker json-file driver 使用
# LOG_FILE=/var/log/xirang/app.log

# 任务执行最大秒数（全局兜底，单个 Policy 可通过 max_execution_seconds 字段覆盖）
# 默认 86400（24 小时）；0 或负数会回退到默认值
# 防止 executor 卡死导致 goroutine 泄漏
# TASK_MAX_EXECUTION_SECONDS=86400

# 初始管理员密码（首次启动时创建 admin 用户的密码）
# 生产环境务必修改为强密码
ADMIN_INITIAL_PASSWORD=change-me-admin-password

# 数据库配置（DB_TYPE: sqlite | postgres）
DB_TYPE=sqlite
SQLITE_PATH=./xirang.db
# DB_TYPE=postgres 时必须提供 DB_DSN
# DB_DSN=host=127.0.0.1 user=xirang password=xirang dbname=xirang port=5432 sslmode=disable
# 注意：生产环境应使用 sslmode=require 或 sslmode=verify-full

# 鉴权配置（JWT_TTL/LOGIN_RATE_WINDOW 使用 Go duration，如 24h、90s）
JWT_SECRET=change-me-in-production
JWT_TTL=24h
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW=1m
LOGIN_FAIL_LOCK_THRESHOLD=5
LOGIN_FAIL_LOCK_DURATION=15m
LOGIN_CAPTCHA_ENABLED=false
LOGIN_SECOND_CAPTCHA_ENABLED=false

# 跨域白名单，多个域名逗号分隔；留空时仅放行同主机 Origin（忽略端口）
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# WebSocket 是否允许空 Origin（默认 false，建议保持关闭）
WS_ALLOW_EMPTY_ORIGIN=false

# 执行器配置
RSYNC_BINARY=rsync

# 敏感字段加密（Node 密码/私钥、SSH Key 私钥）
# 支持 32 字节 base64 或任意字符串（会自动通过 sha256 派生）
# 留空会使用内置开发密钥（仅本地开发可接受，生产必须显式设置）
DATA_ENCRYPTION_KEY=change-me-encryption-key

# 旧版加密密钥（密钥轮替期间用于解密历史数据，确认无 v1 数据后清理）
# 仅在轮替主密钥时设置；不轮替时留空
# DATA_ENCRYPTION_LEGACY_KEY=

# SMTP（仅 email 通知通道需要）
# SMTP_HOST 为空时 email 通道会失败并记录投递失败
# SMTP_FROM 为空时会回退使用 SMTP_USER
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# 强制 TLS 连接（465 隐式 / 587 STARTTLS），设为 false 回退到明文（v0.18+ 默认 true）
# SMTP_REQUIRE_TLS=true

# 通知通道安全
# 开启后会阻断 webhook/slack/telegram 指向私网/回环地址
INTEGRATION_BLOCK_PRIVATE_ENDPOINTS=false

# SSH 主机校验
# 生产建议开启，配合 known_hosts 校验远端主机指纹
SSH_STRICT_HOST_KEY_CHECKING=false
SSH_KNOWN_HOSTS_PATH=~/.ssh/known_hosts

# rsync 前置校验
# 路径白名单（逗号分隔，留空表示不限制）
RSYNC_ALLOWED_SOURCE_PREFIXES=
RSYNC_ALLOWED_TARGET_PREFIXES=
# 本地目标目录最小剩余空间（GB，0 表示不检查）
RSYNC_MIN_FREE_GB=0

# 告警去重窗口（同节点+同任务+同错误码）
# 0 表示关闭去重窗口，仅保留 cooldown/threshold 逻辑
ALERT_DEDUP_WINDOW=10m

# ── 日志 ──
# 日志级别（debug | info | warn | error，留空使用 info）
LOG_LEVEL=

# ── 数据保留 ──
# 任务流量数据保留天数
TASK_TRAFFIC_RETENTION_DAYS=8
# 任务执行记录保留天数
TASK_RUN_RETENTION_DAYS=90
# 备份保留策略检查间隔（最小 1m）；定期清理过期备份并检查存储空间
RETENTION_CHECK_INTERVAL=6h
# 完整性检查频率倍数：每隔多少个保留清理周期运行 restic check / rclone check
# 默认 4，即 RETENTION_CHECK_INTERVAL=6h 时每 24h 一次
INTEGRITY_CHECK_MULTIPLIER=4
# 节点日志默认保留天数（节点未单独配置时生效）
LOG_RETENTION_DAYS_DEFAULT=30
# 已过期静默规则的审计保留天数，超出后删除
SILENCE_RETENTION_DAYS=30

# ── 备份存储健康 ──
# 本地备份存储最低剩余空间（GB），低于此值触发告警
BACKUP_STORAGE_MIN_FREE_GB=10
# 本地备份存储最大使用率（%），超过此值触发告警
BACKUP_STORAGE_MAX_USAGE_PCT=90
# 备份健康面板判定节点备份过期的小时阈值
BACKUP_STALE_THRESHOLD_HOURS=48

# ── 节点探测 ──
# 探测间隔（最小 30s）
NODE_PROBE_INTERVAL=5m
# 连续失败多少次标记节点离线
NODE_PROBE_FAIL_THRESHOLD=3
# 并发探测数
NODE_PROBE_CONCURRENCY=10

# ── WebSocket ──
# 最大连接数
WS_MAX_CONNECTIONS=100

# ── SSH 扩展 ──
# 严格校验关闭时，是否自动接受新主机指纹
SSH_AUTO_ACCEPT_NEW_HOSTS=true

# ── 文件浏览器 ──
# 设为 true 允许浏览任意路径（默认仅允许备份目录）
# FILE_BROWSER_ALLOW_ALL=true

# ── 批量命令 ──
# 自定义命令黑名单（逗号分隔正则，留空使用内置规则）
# BATCH_COMMAND_BLACKLIST=rm\s+-rf,mkfs

# ── 备份工具路径 ──
RCLONE_BINARY=rclone
RESTIC_BINARY=restic

# ── 异常检测（EWMA + 磁盘容量预测） ──
# 异常检测默认启用，但默认仅写入 anomaly_events 表供诊断，不升级为告警/通知；
# 需要恢复异常通知时把 ANOMALY_ALERTS_ENABLED 设为 true
ANOMALY_ENABLED=true
ANOMALY_ALERTS_ENABLED=false
# EWMA 平滑因子 α
ANOMALY_EWMA_ALPHA=0.3
# EWMA 异常判定标准差倍数（默认更保守以降低低负载误报）
ANOMALY_EWMA_SIGMA=5.0
# EWMA 回看样本窗口（小时）
ANOMALY_EWMA_WINDOW_HOURS=6
# EWMA 最少样本数
ANOMALY_EWMA_MIN_SAMPLES=24
# 磁盘预测阈值，预计 ≤ 该天数爆满时记录事件
ANOMALY_DISK_FORECAST_DAYS=7
# 磁盘预测所需最少历史小时数
ANOMALY_DISK_FORECAST_MIN_HISTORY_HOURS=72
# 异常事件保留天数
ANOMALY_EVENTS_RETENTION_DAYS=30

# ── 版本检查（可选） ──
# 推荐指向 GitHub latest release API；当前仅支持稳定版 semver 响应
# 未设置时版本检查接口返回"未配置"
# VERSION_CHECK_URL=https://api.github.com/repos/xiangnan0811/xirang/releases/latest

# ── 系统自助数据库备份 ──
# 数据库备份文件存放目录（默认 ./backups，相对于 SQLite 文件目录）
# DB_BACKUP_DIR=./backups
# 系统自助 SQLite 备份接口保留的最大备份数量
DB_BACKUP_MAX_COUNT=20

# ── Prometheus remote-write（可选；留空禁用远程推送） ──
# 设置 URL 后，每次节点探测样本同时通过 snappy+protobuf 推送到外部 TSDB
# （Mimir/Cortex/VictoriaMetrics/Grafana Cloud）。FanSink 吞掉远程错误，
# DBSink 不受影响。生产环境的 Bearer Token 建议用环境变量配置。
METRICS_REMOTE_URL=
METRICS_REMOTE_BEARER_TOKEN=
METRICS_REMOTE_TIMEOUT=5s

# ── /metrics 端点鉴权 + 限流 ──
# /metrics 公开会泄露所有路由清单 + 流量画像，建议生产环境配置 token。
# 留空时保持现有公开行为（兼容），并每 10 分钟在日志中提示一次。
# 配置后 Prometheus 抓取需通过 bearer_token / bearer_token_file 提供匹配 token。
# METRICS_TOKEN=replace-with-strong-random-token
# /metrics 独立限流桶（per IP），与 /api 分离。
# 默认 5 req/s 对应 Prometheus 通常 15-30s 一次抓取，留有充足余量。
METRICS_RATE_LIMIT=5
METRICS_RATE_WINDOW=1s
