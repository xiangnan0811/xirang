# 生产环境建议
SERVER_ADDR=:8080

# 数据库（二选一，DB_TYPE=postgres 时 DB_DSN 必填）
DB_TYPE=postgres
DB_DSN=host=postgres user=xirang password=change-me dbname=xirang port=5432 sslmode=disable
# DB_TYPE=sqlite
# SQLITE_PATH=/data/xirang.db

# 鉴权（务必替换为强随机密钥）
# JWT_TTL/LOGIN_RATE_WINDOW 使用 Go duration，如 12h、90s
JWT_SECRET=replace-with-a-strong-random-secret
JWT_TTL=12h
LOGIN_RATE_LIMIT=8
LOGIN_RATE_WINDOW=1m
LOGIN_FAIL_LOCK_THRESHOLD=5
LOGIN_FAIL_LOCK_DURATION=15m
LOGIN_CAPTCHA_ENABLED=true
LOGIN_SECOND_CAPTCHA_ENABLED=false

# 只允许前端域名访问，多个域名用逗号分隔
CORS_ALLOWED_ORIGINS=https://xirang.example.com

# 执行器
EXECUTOR_SHELL=/bin/sh
RSYNC_BINARY=rsync

# 敏感字段加密（务必使用强随机密钥，推荐 32 字节 base64）
# 不建议留空；留空会回退到内置开发密钥
DATA_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# SMTP（启用 email 通知通道时必填）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alert@example.com
SMTP_PASS=replace-with-smtp-password
# SMTP_FROM 为空时会回退到 SMTP_USER
SMTP_FROM=alert@example.com

# 通知通道安全
# 开启后会阻断 webhook/slack/telegram 指向私网/回环地址
INTEGRATION_BLOCK_PRIVATE_ENDPOINTS=true

# SSH 主机校验
# 生产建议开启，配合 known_hosts 校验远端主机指纹
SSH_STRICT_HOST_KEY_CHECKING=true
SSH_KNOWN_HOSTS_PATH=~/.ssh/known_hosts

# rsync 前置校验
# 路径白名单（逗号分隔，留空表示不限制）
RSYNC_ALLOWED_SOURCE_PREFIXES=
RSYNC_ALLOWED_TARGET_PREFIXES=
# 本地目标目录最小剩余空间（GB，0 表示不检查）
RSYNC_MIN_FREE_GB=10

# 告警去重窗口（同节点+同任务+同错误码）
ALERT_DEDUP_WINDOW=10m
