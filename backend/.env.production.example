# 生产环境建议
SERVER_ADDR=:8080

# 应用环境
APP_ENV=production

# 版本检查（可选）
# 推荐指向 GitHub latest release API；当前仅支持稳定版 semver 响应。
VERSION_CHECK_URL=https://api.github.com/repos/xiangnan0811/xirang/releases/latest

# 初始管理员密码（首次启动时创建 admin 用户的密码，务必使用强密码）
ADMIN_INITIAL_PASSWORD=replace-with-strong-admin-password

# 数据库（二选一，DB_TYPE=postgres 时 DB_DSN 必填）
DB_TYPE=postgres
DB_DSN=host=postgres user=xirang password=change-me dbname=xirang port=5432 sslmode=require
# DB_TYPE=sqlite
# SQLITE_PATH=/data/xirang.db

# 鉴权（务必替换为强随机密钥）
# JWT_TTL/LOGIN_RATE_WINDOW 使用 Go duration，如 12h、90s
JWT_SECRET=replace-with-a-strong-random-secret
JWT_TTL=12h
LOGIN_RATE_LIMIT=8
LOGIN_RATE_WINDOW=1m
LOGIN_FAIL_LOCK_THRESHOLD=5
LOGIN_FAIL_LOCK_DURATION=15m
LOGIN_CAPTCHA_ENABLED=true
LOGIN_SECOND_CAPTCHA_ENABLED=false

# 只允许前端域名访问，多个域名用逗号分隔
CORS_ALLOWED_ORIGINS=https://xirang.example.com
# 生产建议保持 false，避免无 Origin 连接绕过来源校验
WS_ALLOW_EMPTY_ORIGIN=false

# 执行器
RSYNC_BINARY=rsync

# 敏感字段加密（务必使用强随机密钥，推荐 32 字节 base64）
# 不建议留空；留空会回退到内置开发密钥
DATA_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# SMTP（启用 email 通知通道时必填）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alert@example.com
SMTP_PASS=replace-with-smtp-password
# SMTP_FROM 为空时会回退到 SMTP_USER
SMTP_FROM=alert@example.com

# 通知通道安全
# 开启后会阻断 webhook/slack/telegram 指向私网/回环地址
INTEGRATION_BLOCK_PRIVATE_ENDPOINTS=true

# SSH 主机校验
# 生产建议开启，配合 known_hosts 校验远端主机指纹
SSH_STRICT_HOST_KEY_CHECKING=true
SSH_KNOWN_HOSTS_PATH=~/.ssh/known_hosts

# rsync 前置校验
# 路径白名单（逗号分隔，留空表示不限制）
RSYNC_ALLOWED_SOURCE_PREFIXES=
RSYNC_ALLOWED_TARGET_PREFIXES=
# 本地目标目录最小剩余空间（GB，0 表示不检查）
RSYNC_MIN_FREE_GB=10

# 告警去重窗口（同节点+同任务+同错误码）
ALERT_DEDUP_WINDOW=10m

# ── 日志 ──
# 日志级别（debug | info | warn | error，留空使用 info）
LOG_LEVEL=info

# ── 数据保留 ──
# 任务流量数据保留天数
TASK_TRAFFIC_RETENTION_DAYS=8
# 任务执行记录保留天数
TASK_RUN_RETENTION_DAYS=90

# ── 节点探测 ──
# 探测间隔（最小 30s）
NODE_PROBE_INTERVAL=5m
# 连续失败多少次标记节点离线
NODE_PROBE_FAIL_THRESHOLD=3
# 并发探测数
NODE_PROBE_CONCURRENCY=20

# ── WebSocket ──
# 最大连接数
WS_MAX_CONNECTIONS=100

# ── SSH 扩展 ──
# 是否自动接受首次出现的主机指纹（默认 true，已知主机密钥变更仍会拒绝）
SSH_AUTO_ACCEPT_NEW_HOSTS=true

# ── 文件浏览器 ──
# 设为 true 允许浏览任意路径（默认仅允许备份目录）
# FILE_BROWSER_ALLOW_ALL=true

# ── 批量命令 ──
# 自定义命令黑名单（逗号分隔正则，留空使用内置规则）
# BATCH_COMMAND_BLACKLIST=rm\s+-rf,mkfs

# ── 备份工具路径 ──
RCLONE_BINARY=rclone
RESTIC_BINARY=restic
